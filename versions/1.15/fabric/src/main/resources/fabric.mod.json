{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${version}",
  "name": "${mod_name}",
  "description": "${description}",
  "authors": [
    "${mod_author}"
  ],
  "contact": {},
  "license": "${license}",
  "icon": "assets/${mod_id}/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.iamkaf.konfig.fabric.KonfigFabric"
    ],
    "client": [
      "com.iamkaf.konfig.fabric.KonfigFabricClient"
    ]
  },
  "mixins": [
    "konfig.fabric.compat.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${fabric_loader_version}",
    "minecraft": "${minecraft_version}",
    "fabric": "*"
  }
}
